include-file = $HOME/.config/polybar/colours
include-file = $HOME/.config/polybar/modules

[bar/mybar]
width = 96%
height = 26pt
radius = 10
offset-x = 2%
offset-y = 0.5%
fixed-center = true
bottom = false

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 3pt

border-size = 0
border-color = ${colors.purple}

padding-left = 0
padding-right = 1

module-margin = 1

separator = |
separator-foreground = ${colors.green}

font-0 = monospace:size=12;2
font-1 = Font Awesome 6 Free:style=solid:pixelsize=14;3
font-2 = Font Awesome 6 Brands:style=solid:pixelsize=14;3
font-3 = JetBrainMono Nerd Font;2
font-4 = Iosevka Nerd Font:style=regular:pixelsize=18;3

modules-left = i3
modules-center = mpd
modules-right = pulseaudio filesystem battery update-mgr wlan date
#modules-right = pulseaudio filesystem memory cpu battery update-mgr wlan date

cursor-click = pointer
cursor-scroll = ns-resize

enable-ipc = true
tray-position = none
wm-restack = i3
override-redirect = true

[settings]
screenchange-reload = true
pseudo-transparency = false

; vim:ft=dosini
