include=/home/will/.cache/wal/colors-mako-custom
# GLOBAL
max-history=100
sort=-time

# BINDING OPTIONS
on-button-left=dismiss
on-button-middle=none
on-button-right=dismiss-all
on-touch=dismiss
# on-notify=exec mpv /usr/share/sounds/freedesktop/stereo/message.oga

# STYLE OPTIONS
font=Fantasque Sans Mono 11
width=400
height=100
outer-margin=8
padding=15
border-size=1
border-radius=10
icons=1
max-icon-size=48
icon-location=left
markup=1
actions=1
history=1
text-alignment=center
default-timeout=5000
ignore-timeout=0
max-visible=5
layer=overlay
anchor=bottom-right


# See .config/scripts/media-notify.sh
[app-name="media-notifier"]
max-icon-size=96
